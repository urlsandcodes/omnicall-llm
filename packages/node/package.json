{
  "name": "@urlsandcodes/omnicall-llm",
  "version": "1.0.0",
  "description": "Unified multi-provider LLM caller with automatic fallback",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:cjs && npm run build:esm && npm run build:post",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:post": "echo '{\"type\": \"commonjs\"}' > dist/cjs/package.json && echo '{\"type\": \"module\"}' > dist/esm/package.json",
    "test": "node --test dist/cjs/test/omnicall.test.js"
  },
  "keywords": [
    "llm",
    "gemini",
    "groq",
    "cerebras",
    "sambanova",
    "openrouter",
    "mistral",
    "openai",
    "fallback",
    "unified"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
